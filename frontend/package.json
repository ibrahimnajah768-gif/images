{
  "name": "elevate-ai",
  "version": "0.1.0",
  "description": "AI Image Enhancement App",
  "author": "Your Name",
  "homepage": ".",
  "main": "public/electron.js",
  "dependencies": {
    "@supabase/supabase-js": "^2.43.1",
    "@testing-library/jest-dom": "^5.17.0",
    "@testing-library/react": "^13.4.0",
    "@testing-library/user-event": "^13.5.0",
    "axios": "^1.6.8",
    "electron-is-dev": "^2.0.0",
    "lucide-react": "^0.372.0",
    "react": "^18.2.0",
    "react-compare-image": "^3.4.0",
    "react-dom": "^18.2.0",
    "react-scripts": "5.0.1",
    "web-vitals": "^2.1.4"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "electron": "electron .",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.elevate.ai",
    "productName": "Elevate AI",
    "asar": false,
    "artifactName": "${productName}-${version}-${arch}.${ext}",
    "files": [
      "build/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": ["portable"],
      "executableName": "ElevateAI"
    }
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "electron": "^30.0.1",
    "electron-builder": "^24.13.3",
    "electron-is-dev": "^2.0.0"
  }
}